# Set default behavior to automatically normalize line endings.
* text=auto

# Web files will be checked out with Windows CRLF line endings locally and committed as LF in repository
*.html text eol=crlf
*.css text eol=crlf
*.js text eol=crlf
*.json text eol=crlf
*.md text eol=crlf
*.txt text eol=crlf
